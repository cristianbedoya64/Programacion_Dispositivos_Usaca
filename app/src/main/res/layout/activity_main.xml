<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cine_black"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="@string/title_app"
            android:textColor="@color/cine_gold"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:hint="ID"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etNombrePelicula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Nombre de pelicula"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etNombreCine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Nombre del cine"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etNumeroSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Numero de sala"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Fecha (DD/MM/AAAA)"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Hora (HH:MM)"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etNumeroEntradas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Numero de entradas"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <EditText
            android:id="@+id/etCostoTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Costo total"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:textColor="@color/cine_white"
            android:textColorHint="@color/cine_hint" />

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/cine_red"
            android:text="Guardar"
            android:textColor="@color/cine_white" />

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/cine_gold"
            android:text="Buscar"
            android:textColor="@color/cine_black" />

        <Button
            android:id="@+id/btnActualizar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/cine_red_dark"
            android:text="Actualizar"
            android:textColor="@color/cine_white" />

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/cine_gray"
            android:text="Eliminar"
            android:textColor="@color/cine_white" />

    </LinearLayout>

</ScrollView>
